# App Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

## Database
DATABASE_URL=postgresql://user:pass@localhost:5432/ai_generator?pgbouncer=true
DIRECT_URL=postgresql://user:pass@localhost:5432/ai_generator
DATABASE_SSL=false

# JWT
JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-from-console
GOOGLE_CLIENT_SECRET=your-google-client-secret-from-console
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# S3/R2 (Cloudflare R2 é compatível com S3)
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=ai-generations
S3_PUBLIC_URL=https://cdn.theaimodelab.com.br/storage/v1/object/public/ai-generations # CDN URL para servir arquivos

# The AI Model Lab Provider (servico externo que faz todas as geracoes de IA)
THEAIMODELAB_PROVIDER_URL=http://localhost:3001
THEAIMODELAB_API_KEY=

# Pagamentos
STRIPE_SECRET_KEY=           # sk_test_... (dev) ou sk_live_... (prod)
STRIPE_WEBHOOK_SECRET=       # whsec_... do Stripe Dashboard
STRIPE_SUCCESS_URL=http://localhost:5173/payment/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5173/payment/cancel

# Stripe Price IDs (v5 pricing — ,90)
STRIPE_PRICE_PLAN_STARTER=   # live: price_1TFgcaBFQnG9Nke5RUqrwaMR (R$39,90/mês)
STRIPE_PRICE_PLAN_CREATOR=   # live: price_1TFgcbBFQnG9Nke5b4QqLHwU (R$89,90/mês)
STRIPE_PRICE_PLAN_PRO=       # live: price_1TFgccBFQnG9Nke5c5GC5onO (R$179,90/mês)
STRIPE_PRICE_PLAN_STUDIO=    # live: price_1TFgcdBFQnG9Nke5iKG0gMWe (R$369,90/mês)
STRIPE_PRICE_BOOST_P=        # live: price_1TFgceBFQnG9Nke5CvuZNGEV (R$14,90)
STRIPE_PRICE_BOOST_M=        # live: price_1TFgcfBFQnG9Nke5RBKX91I4 (R$26,90)
STRIPE_PRICE_BOOST_G=        # live: price_1TFgcgBFQnG9Nke5IhiNaGPw (R$36,90)

MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ASAAS (PIX para boost — cobrança única; quando ligar PIX Automático para
# assinaturas, reusar a mesma API key)
# Sandbox: https://api-sandbox.asaas.com  |  Produção: https://api.asaas.com
ASAAS_API_KEY=               # $aact_... (gerado no painel do ASAAS)
ASAAS_BASE_URL=https://api-sandbox.asaas.com
ASAAS_WEBHOOK_SECRET=        # token livre — configurar igual no webhook do painel ASAAS

# Hotmart (webhook de compra de curso → pending grant de free generations)
HOTMART_HOTTOK=             # token configurado no painel da Hotmart

# Greenn (webhook de compra de curso → pending grant de free generations)
GREENN_WEBHOOK_TOKEN=       # token compartilhado: enviado via ?token= ou header x-greenn-token

# Cartpanda (webhook de compra → pending grant de free generations)
CARTPANDA_WEBHOOK_TOKEN=    # token compartilhado: enviado via ?token= ou header x-cartpanda-token

# Perfect Pay (webhook POST /api/v1/webhooks/perfectpay) — MONETIZAÇÃO POR ASSINATURA MENSAL
#  - Assinatura mensal: plan.code casado com plans.perfectpay_plan_code → cria/renova
#    a assinatura recorrente (a PerfectPay dispara o webhook a cada cobrança mensal).
#  - Cancelamento/reembolso/chargeback: revoga a assinatura (acesso até fim do período
#    no cancelamento normal; imediato em reembolso/chargeback).
#  - Demais produtos (curso): libera pending grant de free generations por email.
PERFECTPAY_WEBHOOK_TOKEN=   # token compartilhado: enviado via payload.token, ?token= ou header x-perfectpay-token
# Códigos de plano (default = último segmento do link de checkout; preencher só se o
# code do postback for diferente). Casam com plans.perfectpay_plan_code.
PERFECTPAY_PLAN_CREATOR=    # ex: PPU38CQDTOF
PERFECTPAY_PLAN_PRO=        # ex: PPU38CQDTOD
PERFECTPAY_PLAN_ADVANCED=   # ex: PPU38CQDTOA
PERFECTPAY_PLAN_STUDIO=     # ex: PPU38CQDTOH

# Links de checkout da assinatura mensal recorrente (PerfectPay) — o front redireciona.
CHECKOUT_URL_CREATOR=       # https://checkout.centerpag.com/pay/PPU38CQDTOF  (R$89,90/mês)
CHECKOUT_URL_PRO=           # https://checkout.centerpag.com/pay/PPU38CQDTOD  (R$179,90/mês)
CHECKOUT_URL_ADVANCED=      # https://checkout.centerpag.com/pay/PPU38CQDTOA  (R$249,90/mês)
CHECKOUT_URL_STUDIO=        # https://checkout.centerpag.com/pay/PPU38CQDTOH  (R$369,90/mês)

# Redis (BullMQ + Pub/Sub)
REDIS_URL=redis://default:password@localhost:6379

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Firebase (Phone Auth — verificação de SMS no cadastro)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM_EMAIL=The AI Model Lab <noreply@theaimodelab.ai>
FRONTEND_URL=http://localhost:5173

# Meta Ads tracking
META_PIXEL_ID=1327084455720433
META_ACCESS_TOKEN=              # token CAPI gerado no Events Manager (nunca commitar valor real)
META_GRAPH_API_VERSION=v23.0
META_TEST_EVENT_CODE=           # opcional: usar em teste no Events Manager

# Watermark
WATERMARK_IMAGE_PATH=assets/watermark.png

# Replicate (legado — não mais usado; Seedream migrou para WaveSpeed)
REPLICATE_API_TOKEN=

# WaveSpeed — Seedream V5.0 Pro (imagem: sem-censura + undress) e OmniVoice (áudio)
WAVESPEED_API_KEY=
WAVESPEED_BASE_URL=https://api.wavespeed.ai

# Deepdeep (n88ed) — modelo de imagem image-to-image
DEEPDEEP_API_KEY=
DEEPDEEP_BASE_URL=https://use.n88ed.app
DEEPDEEP_POLL_INTERVAL_MS=5000

# Kling V3 Turbo (image-to-video) — usa a mesma API kie.ai do NANO_BANANA_*.
# Não precisa de chave própria; reutiliza NANO_BANANA_BASE_URL / NANO_BANANA_API_KEY.

# ComfyDeploy (WanImageToVideo — modelo de vídeo NSFW/legacy)
COMFYDEPLOY_API_KEY=
COMFYDEPLOY_DEPLOYMENT_ID=
COMFYDEPLOY_BASE_URL=https://api.comfydeploy.com

# HeyGen (clonagem de avatar — Digital Twin v3)
HEYGEN_API_KEY=
HEYGEN_BASE_URL=https://api.heygen.com
HEYGEN_WEBHOOK_SECRET=
# {avatarId} é substituído em runtime pelo backend ao montar a URL final
HEYGEN_CONSENT_REROUTE_URL=http://localhost:3000/workspace/avatars/{avatarId}?consent=done
AVATAR_TRAINING_CREDITS_PHOTO=1250
AVATAR_TRAINING_CREDITS_DIGITAL_TWIN=2000
AVATAR_TRAINING_TIMEOUT_MIN=90
